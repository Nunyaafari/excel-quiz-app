[debug] [2026-03-07T14:42:11.858Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/excel-quiz-app-28d21/rulesets {"name":"projects/excel-quiz-app-28d21/rulesets/da4fb1c2-b9d7-4080-80d0-55d843d26241","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isAdmin() {\n      return isSignedIn()\n        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))\n        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;\n    }\n    \n    // Users collection - users can only read/write their own data\n    match /users/{userId} {\n      allow read, write: if isSignedIn() && request.auth.uid == userId;\n    }\n\n    // Admin membership docs\n    match /admins/{adminId} {\n      allow read: if isSignedIn() && request.auth.uid == adminId;\n      allow write: if false;\n    }\n    \n    // Questions collection - read public, write only for admins\n    match /questions/{questionId} {\n      allow read: if true; // Public access for quiz questions\n      allow write: if isAdmin();\n    }\n    \n    // Quiz attempts - users can create and read their own attempts\n    match /quizAttempts/{attemptId} {\n      allow create: if isSignedIn();\n      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;\n      allow update, delete: if false; // Prevent modification of quiz attempts\n    }\n    \n    // Training materials - read public, write only for admins\n    match /trainingMaterials/{materialId} {\n      allow read: if true; // Public access for training materials\n      allow write: if isAdmin();\n    }\n  }\n}\n","name":"/Users/kwame/Desktop/excel-quiz-app/firestore.rules"}]},"createTime":"2026-03-07T14:42:12.333116Z","metadata":{"services":["cloud.firestore"]}}
