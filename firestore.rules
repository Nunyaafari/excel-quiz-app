rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Questions collection - read public, write only for admins
    match /questions/{questionId} {
      allow read: if true; // Public access for quiz questions
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Quiz attempts - users can create and read their own attempts
    match /quizAttempts/{attemptId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Prevent modification of quiz attempts
    }
    
    // Training materials - read public, write only for admins
    match /trainingMaterials/{materialId} {
      allow read: if true; // Public access for training materials
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}