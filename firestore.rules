rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    // Users collection - users can read/write their own data, admins can read for analytics
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Admin membership docs
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }

    // Questions collection - read public, write only for admins
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Quiz attempts - users can create and read their own attempts, admins can read for reporting
    match /quizAttempts/{attemptId} {
      allow create: if request.resource.data.userId is string
        && request.resource.data.score is number
        && request.resource.data.totalQuestions is number
        && request.resource.data.correctAnswers is number
        && request.resource.data.date is timestamp
        && request.resource.data.categoryScores is map
        && request.resource.data.wrongCategories is list
        && request.resource.data.questions is list;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    // Analytics events - public create for landing attribution, admin read only
    match /analyticsEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.type is string
        && request.resource.data.source is string
        && (!('path' in request.resource.data) || request.resource.data.path is string)
        && (!('referrer' in request.resource.data) || request.resource.data.referrer is string)
        && (!('userAgent' in request.resource.data) || request.resource.data.userAgent is string);
      allow update, delete: if false;
    }

    // Administered quiz batches
    match /quizBatches/{batchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reviews - public read, signed-in create only
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.resource.data.userId is string
        && request.resource.data.displayName is string
        && request.resource.data.rating is number
        && request.resource.data.comment is string
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    // Quiz leads - admin read, public create
    match /quizLeads/{leadId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.userId is string
        && request.resource.data.email is string
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    // Training requests - admin read, public create
    match /trainingRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.organization is string;
      allow update, delete: if false;
    }

    // Training materials - read public, write only for admins
    match /trainingMaterials/{materialId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
