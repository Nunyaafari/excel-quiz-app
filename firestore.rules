rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    // Users collection - users can read/write their own data, admins can read for analytics
    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Admin membership docs
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }

    // Questions collection - read public, write only for admins
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Quiz attempts - users can create and read their own attempts, admins can read for reporting
    match /quizAttempts/{attemptId} {
      allow create: if request.resource.data.userId is string
        && request.resource.data.score is number
        && request.resource.data.totalQuestions is number
        && request.resource.data.correctAnswers is number
        && request.resource.data.date is timestamp
        && request.resource.data.categoryScores is map
        && request.resource.data.wrongCategories is list
        && request.resource.data.questions is list;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    // Analytics events - public create for landing attribution, admin read only
    match /analyticsEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.type is string
        && request.resource.data.source is string
        && (!('path' in request.resource.data) || request.resource.data.path is string)
        && (!('referrer' in request.resource.data) || request.resource.data.referrer is string)
        && (!('userAgent' in request.resource.data) || request.resource.data.userAgent is string);
      allow update, delete: if false;
    }

    // Administered quiz batches
    match /quizBatches/{batchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reviews - public read, signed-in create only
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.resource.data.userId is string
        && request.resource.data.displayName is string
        && request.resource.data.rating is number
        && request.resource.data.comment is string
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    // Quiz leads - admin read, public create
    match /quizLeads/{leadId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.userId is string
        && request.resource.data.email is string
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    // Training requests - admin read, public create
    match /trainingRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.organization is string;
      allow update, delete: if false;
    }

    // Training materials - read public, write only for admins
    match /trainingMaterials/{materialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog posts - public can read published posts, admins can manage all posts
    match /blogPosts/{postId} {
      allow get: if isAdmin() || resource.data.status == 'published';
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin()
        && request.resource.data.title is string
        && request.resource.data.slug is string
        && request.resource.data.content is string
        && request.resource.data.excerpt is string
        && request.resource.data.category is string
        && request.resource.data.tags is list
        && request.resource.data.authorName is string
        && request.resource.data.status is string
        && (request.resource.data.status == 'draft' || request.resource.data.status == 'published')
        && request.resource.data.featured is bool
        && request.resource.data.seoKeywords is list
        && request.resource.data.updatedAt is timestamp
        && (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp)
        && (!('publishedAt' in request.resource.data) || request.resource.data.publishedAt is timestamp || request.resource.data.publishedAt == null)
        && (!('coverImageUrl' in request.resource.data) || request.resource.data.coverImageUrl is string || request.resource.data.coverImageUrl == null)
        && (!('focusKeyword' in request.resource.data) || request.resource.data.focusKeyword is string || request.resource.data.focusKeyword == null)
        && (!('seoTitle' in request.resource.data) || request.resource.data.seoTitle is string || request.resource.data.seoTitle == null)
        && (!('seoDescription' in request.resource.data) || request.resource.data.seoDescription is string || request.resource.data.seoDescription == null);
    }
  }
}
