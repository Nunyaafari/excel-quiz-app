rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }
    
    // Users collection - users can only read/write their own data
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Admin membership docs
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false;
    }
    
    // Questions collection - read public, write only for admins
    match /questions/{questionId} {
      allow read: if true; // Public access for quiz questions
      allow write: if isAdmin();
    }
    
    // Quiz attempts - users can create and read their own attempts
    match /quizAttempts/{attemptId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Prevent modification of quiz attempts
    }

    // Administered quiz batches
    match /quizBatches/{batchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reviews - public read, signed-in create only
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Quiz leads - admin read, signed-in create only
    match /quizLeads/{leadId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Training requests - admin read, public create
    match /trainingRequests/{requestId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.email is string
        && request.resource.data.phone is string
        && request.resource.data.organization is string;
      allow update, delete: if false;
    }
    
    // Training materials - read public, write only for admins
    match /trainingMaterials/{materialId} {
      allow read: if true; // Public access for training materials
      allow write: if isAdmin();
    }
  }
}
